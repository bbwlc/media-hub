{
  "info": {
    "name": "Media Hub – Profile Action Endpoints",
    "description": "Tests für /verify, /lock, /unlock — erlaubte und unerlaubte Übergänge, mit und ohne ADMIN-Rolle.\n\nReihenfolge einhalten: Die Requests bauen aufeinander auf (Zustandsmaschine).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:8080" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken",  "value": "" },
    { "key": "user3Id",    "value": "3" }
  ],
  "item": [

    {
      "name": "00 – Setup: Login",
      "description": "Tokens holen und als Collection-Variablen speichern. Zuerst ausführen.",
      "item": [
        {
          "name": "Login Admin (user1)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signIn",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Token vorhanden', () => {",
                  "  const token = pm.response.json().token;",
                  "  pm.expect(token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('adminToken', token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User2 (kein Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signIn",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user2\",\n  \"password\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Token vorhanden', () => {",
                  "  const token = pm.response.json().token;",
                  "  pm.expect(token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('userToken', token);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "01 – /verify (UNVERIFIED → VERIFIED)",
      "description": "user3 startet als UNVERIFIED (data.sql).",
      "item": [
        {
          "name": "✅ verify — erlaubt (UNVERIFIED → VERIFIED)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/verify"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Status ist VERIFIED', () => {",
                  "  pm.expect(pm.response.json().status).to.eql('VERIFIED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ verify — unerlaubt (VERIFIED → verify → 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/verify"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Fehlermeldung enthält VERIFIED', () => {",
                  "  pm.expect(pm.response.text()).to.include('VERIFIED');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "02 – /lock (VERIFIED → LOCKED)",
      "description": "user3 ist nach Ordner 01 VERIFIED.",
      "item": [
        {
          "name": "✅ lock — erlaubt (VERIFIED → LOCKED)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/lock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Status ist LOCKED', () => {",
                  "  pm.expect(pm.response.json().status).to.eql('LOCKED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ lock — unerlaubt (LOCKED → lock → 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/lock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Fehlermeldung enthält LOCKED', () => {",
                  "  pm.expect(pm.response.text()).to.include('LOCKED');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "03 – /unlock (LOCKED → VERIFIED)",
      "description": "user3 ist nach Ordner 02 LOCKED.",
      "item": [
        {
          "name": "✅ unlock — erlaubt (LOCKED → VERIFIED)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/unlock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Status ist VERIFIED', () => {",
                  "  pm.expect(pm.response.json().status).to.eql('VERIFIED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ unlock — unerlaubt (VERIFIED → unlock → 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/unlock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Fehlermeldung enthält aktuellen Status', () => {",
                  "  pm.expect(pm.response.text()).to.include('VERIFIED');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "04 – Auth-Schutz",
      "description": "Zugriff ohne ADMIN-Rolle oder ohne Token.",
      "item": [
        {
          "name": "❌ verify mit user2-Token (ROLE_USER → 403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/verify"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ lock mit user2-Token (ROLE_USER → 403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/lock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ unlock mit user2-Token (ROLE_USER → 403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/unlock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ verify ohne Token (→ 403)",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/me/profile/{{user3Id}}/verify"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));",
                  "pm.test('Kein Token im Response', () => {",
                  "  pm.expect(pm.response.text()).to.not.include('token');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "05 – 404 Unbekannte ID",
      "description": "ID 9999 existiert nicht.",
      "item": [
        {
          "name": "❌ verify mit unbekannter ID (→ 404)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/9999/verify"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ lock mit unbekannter ID (→ 404)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/9999/lock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ unlock mit unbekannter ID (→ 404)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/me/profile/9999/unlock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    }

  ]
}